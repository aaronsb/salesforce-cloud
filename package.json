{
  "name": "@aaronsb/salesforce-cloud-mcp",
  "mcpName": "io.github.aaronsb/salesforce-cloud",
  "version": "0.7.2",
  "description": "A Model Context Protocol server for Salesforce",
  "author": "aaronsb",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aaronsb/salesforce-cloud.git"
  },
  "homepage": "https://github.com/aaronsb/salesforce-cloud#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "salesforce",
    "ai",
    "llm",
    "tools"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "salesforce-cloud": "build/index.js"
  },
  "files": [
    "build",
    "!build/__tests__"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "jsforce": "^3.10.19"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^9.39.5",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  }
}
