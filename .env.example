# Salesforce Connected App credentials (required)
SF_CLIENT_ID=your_connected_app_consumer_key
SF_CLIENT_SECRET=your_connected_app_consumer_secret

# User credentials (optional — if omitted, uses client credentials flow)
SF_USERNAME=
SF_PASSWORD=

# Salesforce login URL
# Most orgs use My Domain: https://yourcompany.my.salesforce.com
# Client credentials flow requires My Domain URL, not login.salesforce.com
SF_LOGIN_URL=https://yourcompany.my.salesforce.com
