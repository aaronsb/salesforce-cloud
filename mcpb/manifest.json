{
  "manifest_version": "0.3",
  "name": "salesforce-cloud-mcp",
  "display_name": "Salesforce Cloud",
  "version": "0.5.0",
  "description": "MCP server for Salesforce CRM — manage opportunities, accounts, contacts, SOQL queries, and analytics",
  "author": {
    "name": "aaronsb",
    "url": "https://github.com/aaronsb"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aaronsb/salesforce-cloud.git"
  },
  "homepage": "https://github.com/aaronsb/salesforce-cloud#readme",
  "support": "https://github.com/aaronsb/salesforce-cloud/issues",
  "license": "MIT",
  "keywords": [
    "salesforce",
    "crm",
    "opportunities",
    "soql",
    "mcp"
  ],
  "server": {
    "type": "node",
    "entry_point": "server/index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/server/index.js"
      ],
      "env": {
        "SF_CLIENT_ID": "${user_config.sf_client_id}",
        "SF_CLIENT_SECRET": "${user_config.sf_client_secret}",
        "SF_USERNAME": "${user_config.sf_username}",
        "SF_PASSWORD": "${user_config.sf_password}",
        "SF_LOGIN_URL": "${user_config.sf_login_url}"
      }
    }
  },
  "tools": [
    {
      "name": "execute_soql",
      "description": "Execute SOQL queries against Salesforce"
    },
    {
      "name": "list_objects",
      "description": "List available Salesforce objects"
    },
    {
      "name": "describe_object",
      "description": "Describe a Salesforce object's fields and metadata"
    },
    {
      "name": "search_opportunities",
      "description": "Search for opportunities with filters"
    },
    {
      "name": "get_opportunity_details",
      "description": "Get detailed opportunity information"
    },
    {
      "name": "opportunity_insights",
      "description": "Get AI-powered insights for opportunities"
    },
    {
      "name": "find_similar_opportunities",
      "description": "Find similar opportunities by pattern matching"
    },
    {
      "name": "enrich_opportunity",
      "description": "Enrich opportunity with market intelligence"
    },
    {
      "name": "analyze_conversation",
      "description": "Analyze conversation activity for an opportunity"
    },
    {
      "name": "generate_business_case",
      "description": "Generate a business case document"
    },
    {
      "name": "create_record",
      "description": "Create a new Salesforce record"
    },
    {
      "name": "update_record",
      "description": "Update an existing Salesforce record"
    },
    {
      "name": "delete_record",
      "description": "Delete a Salesforce record"
    },
    {
      "name": "get_user_info",
      "description": "Get current Salesforce user information"
    },
    {
      "name": "analyze",
      "description": "Run analytics on any Salesforce object"
    },
    {
      "name": "batch",
      "description": "Execute multiple operations in a single call"
    }
  ],
  "user_config": {
    "sf_client_id": {
      "type": "string",
      "title": "Client ID",
      "description": "Salesforce Connected App client ID",
      "sensitive": true,
      "required": true
    },
    "sf_client_secret": {
      "type": "string",
      "title": "Client Secret",
      "description": "Salesforce Connected App client secret",
      "sensitive": true,
      "required": true
    },
    "sf_username": {
      "type": "string",
      "title": "Username",
      "description": "Salesforce username (if set, uses password flow; otherwise client credentials flow)"
    },
    "sf_password": {
      "type": "string",
      "title": "Password",
      "description": "Salesforce password (required with username for password flow)",
      "sensitive": true
    },
    "sf_login_url": {
      "type": "string",
      "title": "Login URL",
      "description": "Your Salesforce My Domain URL (e.g., https://company.my.salesforce.com)",
      "required": true
    }
  },
  "compatibility": {
    "platforms": [
      "darwin",
      "win32",
      "linux"
    ]
  }
}
